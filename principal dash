        <label>Action note</label>
        <textarea id="modalNote">Please review the pacing gap and update the mission recovery plan before the next assessment block.</textarea>
      </div>
      <div class="actions" style="margin-top:14px;">
        <button class="btn primary" onclick="saveModalAction()">Save Follow-up</button>
        <button class="btn warning" onclick="showToast('Meeting request added')">Request Meeting</button>
      </div>
    </div>
  </div>

  <div class="toast" id="toast">Saved</div>

  <script>
    function showToast(message) {
      const toast = document.getElementById('toast');
      toast.textContent = message;
      toast.classList.add('show');
      clearTimeout(window.toastTimer);
      window.toastTimer = setTimeout(() => toast.classList.remove('show'), 2400);
    }

    function filterView() {
      const value = document.getElementById('viewFilter').value;
      showToast(`View changed: ${value}`);
    }

    function openActionModal(context) {
      document.getElementById('modalTitle').textContent = `${context} Follow-up`;
      document.getElementById('modalSubtitle').textContent = 'Review the issue, assign an instruction, and save it to the academic record.';
      document.getElementById('actionModal').classList.add('show');
    }

    function openStudentModal(studentName) {
      document.getElementById('modalTitle').textContent = `${studentName} Student Review`;
      document.getElementById('modalSubtitle').textContent = 'View flagged weaknesses, teacher comments, assessment evidence, and recommended intervention.';
      document.getElementById('modalNote').value = `Review ${studentName}'s recent worksheet evidence and ask the teacher to confirm whether a foundation task is needed.`;
      document.getElementById('actionModal').classList.add('show');
    }

    function closeModal() {
      document.getElementById('actionModal').classList.remove('show');
    }

    function saveModalAction() {
      closeModal();
      showToast('Follow-up saved to academic record');
    }

    function savePrincipalNote() {
      const focus = document.getElementById('focusArea').value;
      const note = document.getElementById('principalNote').value.trim();
      if (!note) {
        showToast('Write a note before sending');
        return;
      }
      const list = document.getElementById('noteList');
      const item = document.createElement('div');
      item.className = 'note-item';
      item.innerHTML = `<strong>${focus}</strong><span>${note}</span>`;
      list.prepend(item);
      localStorage.setItem('principalLastNote', note);
      showToast('Principal note sent and saved');
    }

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeModal();
    });
  </script>
