<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mission Control | Teacher Dashboard</title>
  <style>
    :root {
      --bg: #08111f;
      --bg-soft: #111c2f;
      --card: rgba(18, 30, 51, 0.92);
      --card-2: rgba(22, 38, 64, 0.95);
      --text: #eef4ff;
      --muted: #9fb0c8;
      --border: rgba(255,255,255,0.1);
      --accent: #60a5fa;
      --accent-2: #a78bfa;
      --success: #22c55e;
      --warning: #f59e0b;
      --danger: #ef4444;
      --purple: #8b5cf6;
      --shadow: 0 20px 60px rgba(0,0,0,.35);
      --tooltip-bg: #020617;
    }

    html[data-theme="light"] {
      --bg: #f4f7fb;
      --bg-soft: #e8eef7;
      --card: rgba(255,255,255,0.96);
      --card-2: rgba(248,250,252,0.98);
      --text: #0f172a;
      --muted: #64748b;
      --border: rgba(15,23,42,0.12);
      --accent: #2563eb;
      --accent-2: #7c3aed;
      --success: #16a34a;
      --warning: #d97706;
      --danger: #dc2626;
      --purple: #7c3aed;
      --shadow: 0 20px 45px rgba(15,23,42,.12);
      --tooltip-bg: #0f172a;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: radial-gradient(circle at top left, rgba(96,165,250,.18), transparent 30%), var(--bg);
      color: var(--text);
      min-height: 100vh;
    }

    button, select, input { font-family: inherit; }

    .app {
      display: grid;
      grid-template-columns: 260px 1fr;
      min-height: 100vh;
    }

    aside {
      background: linear-gradient(180deg, var(--card), var(--bg-soft));
      border-right: 1px solid var(--border);
      padding: 22px;
      position: sticky;
      top: 0;
      height: 100vh;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 26px;
    }

    .logo {
      width: 42px;
      height: 42px;
      border-radius: 14px;
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      display: grid;
      place-items: center;
      color: white;
      font-weight: 900;
      box-shadow: var(--shadow);
    }

    .brand h1 {
      font-size: 17px;
      margin: 0;
      line-height: 1.1;
    }

    .brand span {
      color: var(--muted);
      font-size: 12px;
    }

    .context-card {
      background: var(--card-2);
      border: 1px solid var(--border);
      padding: 14px;
      border-radius: 20px;
      margin-bottom: 20px;
    }

    .context-card label {
      display: block;
      color: var(--muted);
      font-size: 12px;
      margin-bottom: 6px;
    }

    select {
      width: 100%;
      padding: 10px 12px;
      border-radius: 12px;
      border: 1px solid var(--border);
      background: var(--bg-soft);
      color: var(--text);
      outline: none;
      margin-bottom: 10px;
    }

    nav {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .nav-btn {
      border: 1px solid transparent;
      background: transparent;
      color: var(--muted);
      padding: 12px 14px;
      text-align: left;
      border-radius: 14px;
      cursor: pointer;
      display: flex;
      gap: 10px;
      align-items: center;
      transition: .2s ease;
    }

    .nav-btn:hover, .nav-btn.active {
      background: var(--card-2);
      color: var(--text);
      border-color: var(--border);
    }

    main {
      padding: 22px;
      overflow: auto;
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 18px;
      margin-bottom: 22px;
    }

    .title h2 {
      margin: 0 0 5px;
      font-size: 28px;
    }

    .title p {
      margin: 0;
      color: var(--muted);
    }

    .top-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .btn {
      border: 1px solid var(--border);
      background: var(--card-2);
      color: var(--text);
      padding: 10px 14px;
      border-radius: 13px;
      cursor: pointer;
      transition: .18s ease;
      position: relative;
    }

    .btn:hover { transform: translateY(-1px); border-color: var(--accent); }
    .btn.primary { background: linear-gradient(135deg, var(--accent), var(--accent-2)); color: white; border: 0; }
    .btn.success { background: rgba(34,197,94,.16); border-color: rgba(34,197,94,.35); }
    .btn.warning { background: rgba(245,158,11,.16); border-color: rgba(245,158,11,.35); }
    .btn.danger { background: rgba(239,68,68,.16); border-color: rgba(239,68,68,.35); }

    .grid {
      display: grid;
      grid-template-columns: 1.45fr .8fr;
      gap: 18px;
    }

    .cards {
      display: grid;
      grid-template-columns: repeat(4, minmax(0,1fr));
      gap: 14px;
      margin-bottom: 18px;
    }

    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 18px;
      box-shadow: var(--shadow);
    }

    .metric .label { color: var(--muted); font-size: 12px; }
    .metric .value { font-size: 26px; font-weight: 800; margin-top: 6px; }
    .metric .hint { color: var(--muted); font-size: 12px; margin-top: 6px; }

    .today-card {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 18px;
      align-items: center;
      margin-bottom: 18px;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 10px;
      border-radius: 999px;
      font-size: 12px;
      border: 1px solid var(--border);
      color: var(--text);
    }

    .badge.green { background: rgba(34,197,94,.16); }
    .badge.blue { background: rgba(96,165,250,.16); }
    .badge.orange { background: rgba(245,158,11,.16); }
    .badge.gray { background: rgba(148,163,184,.16); }
    .badge.purple { background: rgba(139,92,246,.16); }
    .badge.red { background: rgba(239,68,68,.16); }

    .mission-title {
      font-size: 24px;
      margin: 10px 0 6px;
    }

    .timeline {
      display: flex;
      gap: 8px;
      overflow-x: auto;
      padding-bottom: 4px;
    }

    .class-path {
      display: flex;
      align-items: stretch;
      gap: 0;
      overflow-x: auto;
      padding: 10px 2px 4px;
      margin-top: 10px;
    }

    .class-arrow {
      min-width: 116px;
      height: 72px;
      border: 1px solid var(--border);
      background: var(--card-2);
      color: var(--text);
      cursor: pointer;
      clip-path: polygon(0 0, calc(100% - 22px) 0, 100% 50%, calc(100% - 22px) 100%, 0 100%, 20px 50%);
      margin-left: -12px;
      padding: 10px 26px 10px 28px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      transition: .18s ease;
    }

    .class-arrow:first-child { margin-left: 0; clip-path: polygon(0 0, calc(100% - 22px) 0, 100% 50%, calc(100% - 22px) 100%, 0 100%); padding-left: 16px; }
    .class-arrow:hover { transform: translateY(-2px); filter: brightness(1.08); }
    .class-arrow.done { background: rgba(34,197,94,.18); border-color: rgba(34,197,94,.45); }
    .class-arrow.current { background: linear-gradient(135deg, rgba(96,165,250,.38), rgba(167,139,250,.32)); border-color: var(--accent); box-shadow: 0 0 0 2px rgba(96,165,250,.14); }
    .class-arrow.next { background: rgba(96,165,250,.13); }
    .class-arrow.overdue { background: rgba(245,158,11,.18); border-color: rgba(245,158,11,.48); }
    .class-arrow.locked { opacity: .55; cursor: not-allowed; }
    .class-arrow strong { font-size: 20px; line-height: 1; }
    .class-arrow span { font-size: 11px; color: var(--muted); margin-top: 6px; white-space: nowrap; }

    .node {
      min-width: 132px;
      background: var(--card-2);
      border: 1px solid var(--border);
      border-radius: 18px;
      padding: 12px;
      cursor: pointer;
    }

    .node.done { border-color: rgba(34,197,94,.55); }
    .node.current { border-color: var(--accent); box-shadow: 0 0 0 2px rgba(96,165,250,.15); }
    .node.overdue { border-color: rgba(245,158,11,.65); }
    .node.locked { opacity: .55; }

    .node small { color: var(--muted); }

    .section { display: none; }
    .section.active { display: block; }

    .filters {
      display: grid;
      grid-template-columns: repeat(5, minmax(120px, 1fr));
      gap: 10px;
      margin: 14px 0;
    }

    table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0 10px;
    }

    th {
      text-align: left;
      color: var(--muted);
      font-size: 12px;
      font-weight: 600;
      padding: 0 12px;
    }

    td {
      background: var(--card-2);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      padding: 13px 12px;
      vertical-align: middle;
    }

    td:first-child { border-left: 1px solid var(--border); border-radius: 16px 0 0 16px; }
    td:last-child { border-right: 1px solid var(--border); border-radius: 0 16px 16px 0; }

    .resource-icons span {
      display: inline-grid;
      place-items: center;
      width: 28px;
      height: 28px;
      border-radius: 10px;
      background: var(--bg-soft);
      border: 1px solid var(--border);
      margin-right: 4px;
      cursor: help;
    }

    .right-stack { display: grid; gap: 18px; }

    .progress-bar {
      height: 10px;
      background: var(--bg-soft);
      border-radius: 999px;
      overflow: hidden;
      border: 1px solid var(--border);
    }

    .progress-fill {
      height: 100%;
      width: 72%;
      background: linear-gradient(90deg, var(--accent), var(--success));
    }

    .list {
      display: grid;
      gap: 10px;
    }

    .list-item {
      padding: 12px;
      border-radius: 16px;
      background: var(--card-2);
      border: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: center;
    }

    .mini-calendar {
      display: grid;
      grid-template-columns: repeat(7, minmax(0, 1fr));
      gap: 7px;
      margin-top: 12px;
    }

    .cal-head {
      color: var(--muted);
      font-size: 11px;
      text-align: center;
      padding-bottom: 4px;
    }

    .cal-day {
      min-height: 54px;
      border-radius: 14px;
      border: 1px solid var(--border);
      background: var(--card-2);
      padding: 7px;
      cursor: pointer;
      transition: .18s ease;
      position: relative;
    }

    .cal-day:hover { transform: translateY(-2px); border-color: var(--accent); }
    .cal-day .date { font-size: 12px; font-weight: 800; }
    .cal-day .event { font-size: 9.5px; color: var(--muted); margin-top: 4px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .cal-day.today { box-shadow: 0 0 0 2px rgba(96,165,250,.18); border-color: var(--accent); }
    .cal-day.assessment { background: rgba(139,92,246,.17); border-color: rgba(139,92,246,.48); }
    .cal-day.chapter { background: rgba(34,197,94,.14); border-color: rgba(34,197,94,.42); }
    .cal-day.mission { background: rgba(96,165,250,.12); }
    .cal-day.overdue { background: rgba(245,158,11,.15); border-color: rgba(245,158,11,.45); }

    .term-calendar {
      display: grid;
      grid-template-columns: repeat(7, minmax(0, 1fr));
      gap: 10px;
      margin-top: 16px;
    }

    .term-day {
      min-height: 96px;
      border: 1px solid var(--border);
      background: var(--card-2);
      border-radius: 18px;
      padding: 10px;
    }

    .term-day strong { font-size: 14px; }
    .term-day p { margin: 7px 0 0; font-size: 12px; color: var(--muted); line-height: 1.3; }

    .page {
      min-height: 420px;
    }

    .detail-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }

    .toast {
      position: fixed;
      right: 22px;
      bottom: 22px;
      background: var(--tooltip-bg);
      color: white;
      padding: 14px 18px;
      border-radius: 16px;
      box-shadow: var(--shadow);
      opacity: 0;
      pointer-events: none;
      transform: translateY(12px);
      transition: .25s ease;
      z-index: 20;
      max-width: 360px;
    }

    .toast.show { opacity: 1; transform: translateY(0); }

    [data-tip] { position: relative; }
    [data-tip]:hover::after {
      content: attr(data-tip);
      position: absolute;
      left: 50%;
      bottom: calc(100% + 9px);
      transform: translateX(-50%);
      background: var(--tooltip-bg);
      color: white;
      font-size: 12px;
      line-height: 1.35;
      padding: 8px 10px;
      border-radius: 10px;
      white-space: nowrap;
      z-index: 30;
      box-shadow: var(--shadow);
    }

    .empty-state {
      padding: 42px;
      text-align: center;
      color: var(--muted);
      border: 1px dashed var(--border);
      border-radius: 22px;
      background: var(--card-2);
    }

    @media (max-width: 1100px) {
      .app { grid-template-columns: 1fr; }
      aside { position: relative; height: auto; }
      .grid, .detail-grid { grid-template-columns: 1fr; }
      .cards { grid-template-columns: repeat(2, minmax(0,1fr)); }
      .filters { grid-template-columns: repeat(2, minmax(0,1fr)); }
    }

    @media (max-width: 640px) {
      main { padding: 14px; }
      .topbar, .today-card { flex-direction: column; display: flex; align-items: flex-start; }
      .cards { grid-template-columns: 1fr; }
      .filters { grid-template-columns: 1fr; }
      table { font-size: 13px; }
      .app { display: block; }
    }
  </style>
</head>
<body>
  <div class="app">
    <aside>
      <div class="brand">
        <div class="logo">MC</div>
        <div>
          <h1>Mission Control</h1>
          <span>Teacher Dashboard</span>
        </div>
      </div>

      <div class="context-card">
        <label>Class</label>
        <select id="classSelect" data-tip="Switch between assigned classes.">
          <option>Year 5A</option>
          <option>Year 5B</option>
          <option>Year 6A</option>
        </select>
        <label>Subject</label>
        <select id="subjectSelect" data-tip="Mission list updates by subject in the final system.">
          <option>Science</option>
          <option>Mathematics</option>
          <option>English</option>
        </select>
      </div>

      <nav>
        <button class="nav-btn active" data-page="overview" data-tip="Daily teaching command center.">🏠 Overview</button>
        <button class="nav-btn" data-page="missions" data-tip="Browse, filter and launch all missions.">🗺️ Mission Grid</button>
        <button class="nav-btn" data-page="progress" data-tip="See class completion, weak areas and assessment readiness.">📈 Class Progress</button>
        <button class="nav-btn" data-page="calendar" data-tip="See the next 30 days and the full term plan.">📅 Calendar</button>
        <button class="nav-btn" data-page="resources" data-tip="Print worksheets, slides and teacher notes.">🖨️ Resources</button>
        <button class="nav-btn" data-page="students" data-tip="View students needing attention.">👥 Student Alerts</button>
        <button class="nav-btn" data-page="settings" data-tip="Teacher preferences and display options.">⚙️ Settings</button>
      </nav>
    </aside>

    <main>
      <div class="topbar">
        <div class="title">
          <h2 id="pageTitle">Overview</h2>
          <p id="pageSubtitle">Year 5A Science · Human Body Block · Week 3</p>
        </div>
        <div class="top-actions">
          <button class="btn" id="themeToggle" data-tip="Switch between dark and light mode.">☀️ Light Mode</button>
          <button class="btn" onclick="goToPage('resources')" data-tip="Open printable lesson materials.">Print Center</button>
          <button class="btn" onclick="goToPage('students')" data-tip="Take attendance or review absences.">Quick Attendance</button>
          <button class="btn primary" onclick="openMission('Mission 4: The Heart')" data-tip="Start today’s recommended classroom mission.">Start Today</button>
        </div>
      </div>

      <section id="overview" class="section active page">
        <div class="cards">
          <div class="card metric" data-tip="Percentage of planned missions completed for this block.">
            <div class="label">Curriculum Progress</div>
            <div class="value">72%</div>
            <div class="hint">18 of 25 missions completed</div>
          </div>
          <div class="card metric" data-tip="Missions that should already have been completed.">
            <div class="label">Overdue Missions</div>
            <div class="value">2</div>
            <div class="hint">Needs attention this week</div>
          </div>
          <div class="card metric" data-tip="Latest average from quizzes and OMR assessments.">
            <div class="label">Assessment Average</div>
            <div class="value">68%</div>
            <div class="hint">Slightly below target</div>
          </div>
          <div class="card metric" data-tip="Students who may need intervention.">
            <div class="label">Student Alerts</div>
            <div class="value">4</div>
            <div class="hint">Below performance threshold</div>
          </div>
        </div>

        <div class="card" style="margin-bottom:18px;">
          <div style="display:flex; justify-content:space-between; gap:14px; align-items:flex-start; flex-wrap:wrap;">
            <div>
              <h3 style="margin-bottom:6px;">Class Number Progression</h3>
              <p style="color:var(--muted); margin-top:0;">Follow the actual teaching sequence, independent of week or date. Click a class number to open its mission.</p>
            </div>
            <span class="badge blue">Current: Class 56</span>
          </div>
          <div class="class-path" aria-label="Class number progression">
            <button class="class-arrow done" onclick="openMission('Class 52: Body Systems')"><strong>52</strong><span>Completed</span></button>
            <button class="class-arrow done" onclick="openMission('Class 53: Skeleton')"><strong>53</strong><span>Completed</span></button>
            <button class="class-arrow overdue" onclick="openMission('Class 54: Muscles')"><strong>54</strong><span>Overdue</span></button>
            <button class="class-arrow done" onclick="openMission('Class 55: Blood Vessels')"><strong>55</strong><span>Completed</span></button>
            <button class="class-arrow current" onclick="openMission('Class 56: The Heart')"><strong>56</strong><span>Today · Heart</span></button>
            <button class="class-arrow next" onclick="openMission('Class 57: Lungs')"><strong>57</strong><span>Next · Lungs</span></button>
            <button class="class-arrow next" onclick="openMission('Class 58: Digestion')"><strong>58</strong><span>Upcoming</span></button>
            <button class="class-arrow locked" onclick="lockedMission()"><strong>59</strong><span>Assessment</span></button>
          </div>
        </div>

        <div class="grid">
          <div>
            <div class="card today-card">
              <div>
                <span class="badge blue">Ready to teach</span>
                <h3 class="mission-title">Mission 4: The Heart</h3>
                <p style="color:var(--muted); margin-top:0;">Students explore how the heart pumps blood and why circulation matters.</p>
                <div class="top-actions" style="justify-content:flex-start; margin-top:14px;">
                  <button class="btn primary" onclick="openMission('Mission 4: The Heart')" data-tip="Open slides and classroom flow.">Start Mission</button>
                  <button class="btn" onclick="openTabWithMessage('resources','Teacher notes opened for Mission 4.')" data-tip="View teacher script and lesson guidance.">Teacher Notes</button>
                  <button class="btn" onclick="openTabWithMessage('resources','Worksheet prepared for printing.')" data-tip="Go to printable worksheet.">Print Worksheet</button>
                  <button class="btn success" onclick="completeMission()" data-tip="Mark this mission complete after teaching.">Mark Completed</button>
                </div>
              </div>
              <div>
                <div class="badge purple">40 min</div>
              </div>
            </div>

            <div class="card" style="margin-bottom:18px;">
              <div style="display:flex; justify-content:space-between; gap:12px; align-items:center; flex-wrap:wrap;">
                <div>
                  <h3 style="margin-bottom:4px;">Upcoming</h3>
                  <p style="color:var(--muted); margin:0; font-size:13px;">Immediate next teaching actions.</p>
                </div>
                <button class="btn" onclick="goToPage('missions')" data-tip="Open full mission grid.">View All</button>
              </div>
              <div class="list" style="margin-top:12px; grid-template-columns: repeat(3, minmax(0, 1fr)); display:grid;">
                <div class="list-item"><span>Tomorrow</span><strong>Lungs</strong></div>
                <div class="list-item"><span>Thursday</span><strong>Digestion</strong></div>
                <div class="list-item"><span>Next Week</span><strong>Assessment</strong></div>
              </div>
            </div>

            <div class="card">
              <h3>Mission Timeline</h3>
              <p style="color:var(--muted);">Click any mission to preview it.</p>
              <div class="timeline">
                <div class="node done" onclick="openMission('Mission 1: Body Systems')"><strong>Body Systems</strong><br><small>Completed</small></div>
                <div class="node done" onclick="openMission('Mission 2: Skeleton')"><strong>Skeleton</strong><br><small>Completed</small></div>
                <div class="node overdue" onclick="openMission('Mission 3: Muscles')"><strong>Muscles</strong><br><small>Overdue</small></div>
                <div class="node current" onclick="openMission('Mission 4: The Heart')"><strong>Heart</strong><br><small>Today</small></div>
                <div class="node" onclick="openMission('Mission 5: Lungs')"><strong>Lungs</strong><br><small>Upcoming</small></div>
                <div class="node locked" onclick="lockedMission()"><strong>Assessment</strong><br><small>Locked</small></div>
              </div>
            </div>
          </div>

          <div class="right-stack">
            <div class="card">
              <h3>Class Health</h3>
              <p style="color:var(--muted);">Current block completion</p>
              <div class="progress-bar"><div class="progress-fill"></div></div>
              <div class="list" style="margin-top:14px;">
                <div class="list-item"><span>Weak topic</span><strong>Muscles</strong></div>
                <div class="list-item"><span>Strong topic</span><strong>Skeleton</strong></div>
                <div class="list-item"><span>Assessment readiness</span><strong>Medium</strong></div>
              </div>
            </div>
            <div class="card">
              <div style="display:flex; justify-content:space-between; gap:12px; align-items:center;">
                <div>
                  <h3 style="margin-bottom:4px;">Next 30 Days</h3>
