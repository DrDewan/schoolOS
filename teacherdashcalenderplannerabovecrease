  <div id="toast" class="toast"></div>

  <script>
    const titles = {
      overview: ['Overview', 'Year 5A Science · Human Body Block · Week 3'],
      missions: ['Mission Grid', 'Browse all curriculum missions and launch today’s class.'],
      progress: ['Class Progress', 'Track completion, delays, weak topics and readiness.'],
      calendar: ['Calendar', 'Next 30 days and full term study overview.'],
      resources: ['Resources', 'Slides, worksheets, teacher notes and quizzes.'],
      students: ['Student Alerts', 'Students who need attention or follow-up.'],
      settings: ['Settings', 'Display, progression and classroom preferences.'],
      missionDetail: ['Mission Detail', 'Teaching package, actions and completion workflow.']
    };

    function goToPage(page) {
      document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
      document.getElementById(page).classList.add('active');
      document.querySelectorAll('.nav-btn').forEach(b => b.classList.toggle('active', b.dataset.page === page));
      document.getElementById('pageTitle').textContent = titles[page][0];
      document.getElementById('pageSubtitle').textContent = titles[page][1];
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    document.querySelectorAll('.nav-btn').forEach(btn => {
      btn.addEventListener('click', () => goToPage(btn.dataset.page));
    });

    function openMission(name) {
      document.getElementById('missionDetailTitle').textContent = name;
      goToPage('missionDetail');
      toast(name + ' opened.');
    }

    function completeMission() {
      toast('Mission marked as completed. Class progress updated.');
    }

    function lockedMission() {
      toast('This assessment unlocks after required missions are completed.');
    }

    function openTabWithMessage(page, message) {
      goToPage(page);
      toast(message);
    }

    function toast(message) {
      const el = document.getElementById('toast');
      el.textContent = message;
      el.classList.add('show');
      clearTimeout(window.toastTimer);
      window.toastTimer = setTimeout(() => el.classList.remove('show'), 2600);
    }

    function filterMissions() {
      const value = document.getElementById('filterStatus').value;
      document.querySelectorAll('#missionTable tr').forEach(row => {
        row.style.display = value === 'all' || row.dataset.status === value ? '' : 'none';
      });
    }

    function filterOnlyOverdue() {
      document.getElementById('filterStatus').value = 'overdue';
      filterMissions();
      toast('Showing overdue missions only.');
    }

    function resetFilters() {
      document.getElementById('filterStatus').value = 'all';
      filterMissions();
      toast('Mission filters reset.');
    }

    function toggleTheme() {
      const html = document.documentElement;
      const next = html.dataset.theme === 'dark' ? 'light' : 'dark';
      html.dataset.theme = next;
      localStorage.setItem('mission-theme', next);
      document.getElementById('themeToggle').textContent = next === 'dark' ? '☀️ Light Mode' : '🌙 Dark Mode';
    }

    document.getElementById('themeToggle').addEventListener('click', toggleTheme);

    const savedTheme = localStorage.getItem('mission-theme');
    if (savedTheme) {
      document.documentElement.dataset.theme = savedTheme;
      document.getElementById('themeToggle').textContent = savedTheme === 'dark' ? '☀️ Light Mode' : '🌙 Dark Mode';
    }

    document.getElementById('classSelect').addEventListener('change', e => {
      toast('Class switched to ' + e.target.value + '.');
      document.getElementById('pageSubtitle').textContent = e.target.value + ' Science · Human Body Block · Week 3';
    });

    document.getElementById('subjectSelect').addEventListener('change', e => {
      toast('Subject switched to ' + e.target.value + '.');
    });
  </script>
